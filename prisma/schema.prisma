// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ======================
// Bewerbungen bleiben unverändert
// ======================
model Application {
  id              String   @id @default(cuid())
  name            String
  role            String
  age             String?
  email           String?
  answers         Json     @default("{}")
  submittedAt     DateTime @default(now())

  // Discord-Daten
  discord_id      String?
  discriminator   String?
  avatar          String?
  account_created DateTime?
}

// ======================
// Benutzer, die Dashboard nutzen
// ======================
model DashboardUser {
  id        String   @id @default(cuid())
  discordId String   @unique @map("discord_id")
  username  String
  avatar    String?

  createdAt DateTime @default(now())

  servers   ServerUser[]
}

// ======================
// Server-Tabelle
// ======================
model Server {
  id        String         @id
  name      String
  icon      String?
  botJoined Boolean        @default(true) @map("bot_joined")
  ownerId   String         @map("owner_id")

  createdAt DateTime       @default(now())

  users     ServerUser[]
  settings  ServerSettings?
  logs      DashboardLog[]
  modules   ServerModule[] // Gegenrelation zu ServerModule
}

// ======================
// Wer darf was auf welchem Server
// ======================
model ServerUser {
  id         String   @id @default(cuid())
  serverId   String   @map("server_id")
  userId     String   @map("user_id")
  role       Role
  categories Json     @default("[]")

  joinedAt   DateTime @default(now())

  server     Server         @relation(fields: [serverId], references: [id])
  user       DashboardUser? @relation(fields: [userId], references: [discordId])

  @@unique([serverId, userId])
}

// ======================
// Server Einstellungen
// ======================
model ServerSettings {
  id          String   @id @default(cuid())
  serverId    String   @unique @map("server_id")

  prefix      String   @default("!")
  language    String   @default("de")

  dashboardEnabled Boolean @default(true)

  server      Server   @relation(fields: [serverId], references: [id])
}

// ======================
// Dashboard Logs
// ======================
model DashboardLog {
  id        String   @id @default(cuid())

  serverId  String
  userId    String

  action    String
  targetId  String?

  createdAt DateTime @default(now())

  server    Server   @relation(fields: [serverId], references: [id])
}

// ======================
// Module (aktiv / deaktiviert)
// ======================
model ServerModule {
  id        String   @id @default(cuid())

  serverId  String   @map("server_id")
  module    String

  enabled   Boolean  @default(true)

  config    Json     @default("{}")

  server    Server   @relation(fields: [serverId], references: [id])

  @@unique([serverId, module])
}

// ======================
// Rollen
// ======================
enum Role {
  OWNER
  CO_OWNER
  PARTNER
}
