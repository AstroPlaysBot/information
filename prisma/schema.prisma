// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ======================
// Bewerbungen bleiben unverändert
// ======================
model Application {
  id              String   @id @default(cuid())
  name            String
  role            String
  age             String?
  email           String?
  answers         Json     @default("{}")
  submittedAt     DateTime @default(now())

  // Discord-Daten
  discord_id      String?
  discriminator   String?
  avatar          String?
  account_created DateTime?
}

// ======================
// Benutzer, die Dashboard nutzen
// ======================
model DashboardUser {
  id        String   @id @default(cuid())
  discordId String   @unique @map("discord_id")
  username  String
}

// ======================
// Server-Tabelle
// ======================
model Server {
  id        String   @id                // Discord Server ID
  name      String
  icon      String?
  botJoined Boolean  @default(true)    @map("bot_joined")
  ownerId   String   @map("owner_id")  // Discord ID des Eigentümers

  users     ServerUser[]
}

// ======================
// Wer darf was auf welchem Server
// ======================
model ServerUser {
  id         String   @id @default(cuid())
  serverId   String   @map("server_id")
  userId     String   @map("user_id")   // Discord User ID
  role       Role
  categories Json     @default("[]")   // Array von Strings

  server     Server   @relation(fields: [serverId], references: [id])

  @@unique([serverId, userId])
}

// ======================
// Rollen: Eigentümer, Co-Owner, Teilhaber
// ======================
enum Role {
  OWNER
  CO_OWNER
  PARTNER
}
