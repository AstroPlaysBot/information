// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ======================
// Bewerbungen
// ======================
model Application {
  id              String   @id @default(cuid())
  name            String
  role            String
  age             String?
  email           String?
  answers         Json     @default("{}")
  submittedAt     DateTime @default(now())

  // Discord-Daten
  discord_id      String?
  discriminator   String?
  avatar          String?
  account_created DateTime?

  status          String   @default("PENDING")
  deleted         Boolean  @default(false)
  deletedAt       DateTime?

  interviewDate   DateTime?
  interviewPlace  String?

  oldInterviews   Json?

  interviewFinishedBy String?
  interviewFinishedAt DateTime?

  notes          Json?

  updatedAt      DateTime @updatedAt
  updatedBy      String?

  scheduledBy     String?

  auditLogs AuditLog[]
}

// ======================
// Benutzer Dashboard
// ======================
model DashboardUser {
  id        String   @id @default(cuid())
  discordId String   @unique @map("discord_id")
  username  String
  avatar    String?
  email     String?

  createdAt DateTime @default(now())

  servers   ServerUser[]
  logs      DashboardLog[]
}

// ======================
// Server
// ======================
model Server {
  id        String   @id
  name      String
  icon      String?
  botJoined Boolean  @default(true) @map("bot_joined")
  ownerId   String   @map("owner_id")

  createdAt DateTime @default(now())

  users     ServerUser[]
  settings  ServerSettings?
  logs      DashboardLog[]
  modules   ServerModule[]
}

// ======================
// Server Benutzer / Rechte
// ======================
model ServerUser {
  id         String   @id @default(cuid())

  serverId   String   @map("server_id")
  userId     String   @map("user_id")

  role       Role

  categories Json     @default("[]")

  joinedAt   DateTime @default(now())

  server     Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user       DashboardUser @relation(fields: [userId], references: [discordId], onDelete: Cascade)

  @@unique([serverId, userId])
}

// ======================
// Server Einstellungen
// ======================
model ServerSettings {
  id          String   @id @default(cuid())

  serverId    String   @unique @map("server_id")

  prefix      String   @default("!")
  language    String   @default("de")

  dashboardEnabled Boolean @default(true)

  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

// ======================
// Dashboard Logs
// ======================
model DashboardLog {
  id        String   @id @default(cuid())

  serverId  String
  userId    String

  action    String
  targetId  String?

  createdAt DateTime @default(now())

  server    Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user      DashboardUser @relation(fields: [userId], references: [discordId])
}

// ======================
// Module
// ======================
model ServerModule {
  id        String   @id @default(cuid())

  serverId  String   @map("server_id")
  module    String

  enabled   Boolean  @default(true)

  config    Json     @default("{}")

  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, module])
}

// ======================
// Dashboard Rollen
// ======================
enum Role {
  OWNER
  CO_OWNER
  PARTNER
}

// ======================
// AdminBoard
// ======================
model AdminBoardMember {
  id            String   @id @default(cuid())

  discordId     String   @unique
  discordName   String

  position      String   // z.B. Moderator, Support, etc.

  role          AdminBoardRole @default(VIEWER)

  status        AdminStatus @default(ACTIVE)
  resignedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  email         String?
}

// ======================
// AdminBoard Rollen
// ======================
enum AdminBoardRole {
  OWNER
  PERSONAL_MANAGER
  VIEWER
}

// ======================
// AdminBoard Kündigung
// ======================
model AdminBoardResignation {
  id          String   @id @default(cuid())

  discordId   String
  discordName String?

  reasonType  String?
  reasonText  String?

  revokeToken String   @unique
  revoked     Boolean  @default(false)

  createdAt   DateTime @default(now())
}

enum AdminStatus {
  ACTIVE
  RESIGNED
}

// ======================
// AdminBoard Logs
// ======================
model AuditLog {
  id              String   @id @default(cuid())

  applicantId     String
  application     Application @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  action          String
  actorDiscordId  String?
  actorName       String?
  meta            Json?

  createdAt       DateTime @default(now())

  @@index([applicantId])
  @@index([createdAt])
}

// ======================
// AdminBoard Neuigkeiten
// ======================
model NewsPost {
  id        String   @id @default(cuid())
  content   String
  authorId   String
  authorName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ======================
// Mail > Ticket 
// ======================
model Ticket {
  id          String   @id @default(cuid())
  ticketId    String   @unique // z.B. APL-4821
  
  senderMail  String
  senderName  String?
  subject     String
  
  badge       String?  // ALLGEMEIN, LOESCHANTRAG, BUG, FEATURE, BESCHWERDE, SONSTIGES
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, CLOSED, ARCHIVED
  
  gmailThreadId String? // für Reply-Threading
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  closedAt    DateTime?
  closedBy    String?
  
  messages    TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  content   String
  fromMail  String   // Absender-Mail
  fromName  String?  // Absender-Name
  isStaff   Boolean  @default(false) // true = vom Team gesendet
  staffId   String?  // discordId wenn isStaff
  staffName String?
  
  gmailMessageId String? // für Deduplizierung
  
  createdAt DateTime @default(now())
  
  @@index([ticketId])
}

model ZentraleAccess {
  id          String   @id @default(cuid())
  discordId   String   @unique
  discordName String
  canAccess   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AvailabilitySettings {
  id        Int      @id @default(1)
  premium   Boolean  @default(true)
  games     Json
  updatedAt DateTime @updatedAt
  discounts Json    @default("{}")
}

// ======================
// Rechtsdokument-Versionen
// ======================
model LegalDocVersion {
  id        String   @id
  version   String
  updatedAt DateTime @updatedAt
}

// ======================
// Wartungsarbeiten
// ======================
model MaintenanceConfig {
  id        String   @id @default(cuid())
  pages     Json     @default("[]")
  updatedAt DateTime @updatedAt
}
